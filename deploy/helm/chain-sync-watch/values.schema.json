{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "chain-sync-watch values",
  "type": "object",
  "additionalProperties": true,
  "required": ["image", "imageWeb", "server", "worker", "web", "migrate", "secrets", "postgresql", "redis"],
  "definitions": {
    "image": {
      "type": "object",
      "required": ["registry", "repository", "pullPolicy"],
      "properties": {
        "registry": {"type": "string", "minLength": 1},
        "repository": {"type": "string", "minLength": 1},
        "tag": {"type": "string"},
        "pullPolicy": {"type": "string", "enum": ["Always", "IfNotPresent", "Never"]}
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {"type": "object"},
        "limits": {"type": "object"}
      }
    },
    "autoscaling": {
      "type": "object",
      "required": ["enabled", "minReplicas", "maxReplicas"],
      "properties": {
        "enabled": {"type": "boolean"},
        "minReplicas": {"type": "integer", "minimum": 1},
        "maxReplicas": {"type": "integer", "minimum": 1},
        "targetCPUUtilizationPercentage": {"type": ["integer", "string"]},
        "targetMemoryUtilizationPercentage": {"type": ["integer", "string"]}
      }
    },
    "pdb": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {"type": "boolean"},
        "minAvailable": {"type": ["integer", "string"]},
        "maxUnavailable": {"type": ["integer", "string"]}
      }
    }
  },
  "properties": {
    "image": {"$ref": "#/definitions/image"},
    "imageWeb": {"$ref": "#/definitions/image"},
    "imagePullSecrets": {"type": "array"},
    "nameOverride": {"type": "string"},
    "fullnameOverride": {"type": "string"},
    "serviceAccount": {
      "type": "object",
      "required": ["create"],
      "properties": {
        "create": {"type": "boolean"},
        "annotations": {"type": "object"},
        "name": {"type": "string"}
      }
    },
    "config": {"type": "object"},
    "secrets": {
      "type": "object",
      "properties": {
        "DATABASE_URL": {"type": "string"},
        "REDIS_URL": {"type": "string"},
        "CSW_SECRET_KEY": {"type": "string"}
      }
    },
    "server": {
      "type": "object",
      "required": ["enabled", "replicaCount", "service"],
      "properties": {
        "enabled": {"type": "boolean"},
        "replicaCount": {"type": "integer", "minimum": 0},
        "podAnnotations": {"type": "object"},
        "resources": {"$ref": "#/definitions/resources"},
        "service": {
          "type": "object",
          "required": ["type", "port"],
          "properties": {
            "type": {"type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"]},
            "port": {"type": "integer", "minimum": 1, "maximum": 65535}
          }
        },
        "livenessProbe": {"type": "object"},
        "readinessProbe": {"type": "object"},
        "terminationGracePeriodSeconds": {"type": "integer", "minimum": 0},
        "preStopSleepSeconds": {"type": "integer", "minimum": 0},
        "autoscaling": {"$ref": "#/definitions/autoscaling"},
        "pdb": {"$ref": "#/definitions/pdb"}
      }
    },
    "worker": {
      "type": "object",
      "required": ["enabled", "replicaCount", "healthPort"],
      "properties": {
        "enabled": {"type": "boolean"},
        "replicaCount": {"type": "integer", "minimum": 0},
        "podAnnotations": {"type": "object"},
        "resources": {"$ref": "#/definitions/resources"},
        "healthPort": {"type": "integer", "minimum": 1, "maximum": 65535},
        "livenessProbe": {"type": "object"},
        "readinessProbe": {"type": "object"},
        "terminationGracePeriodSeconds": {"type": "integer", "minimum": 0},
        "preStopSleepSeconds": {"type": "integer", "minimum": 0},
        "autoscaling": {"$ref": "#/definitions/autoscaling"},
        "pdb": {"$ref": "#/definitions/pdb"}
      }
    },
    "web": {
      "type": "object",
      "required": ["enabled", "replicaCount", "service"],
      "properties": {
        "enabled": {"type": "boolean"},
        "replicaCount": {"type": "integer", "minimum": 0},
        "podAnnotations": {"type": "object"},
        "resources": {"$ref": "#/definitions/resources"},
        "service": {
          "type": "object",
          "required": ["type", "port"],
          "properties": {
            "type": {"type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"]},
            "port": {"type": "integer", "minimum": 1, "maximum": 65535}
          }
        },
        "autoscaling": {"$ref": "#/definitions/autoscaling"},
        "pdb": {"$ref": "#/definitions/pdb"}
      }
    },
    "migrate": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {"type": "boolean"},
        "backoffLimit": {"type": "integer", "minimum": 0},
        "activeDeadlineSeconds": {"type": "integer", "minimum": 1},
        "resources": {"$ref": "#/definitions/resources"}
      }
    },
    "podSecurityContext": {"type": "object"},
    "securityContext": {"type": "object"},
    "ingress": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {"type": "boolean"},
        "className": {"type": "string"},
        "host": {"type": "string"},
        "annotations": {"type": "object"},
        "webPath": {"type": "string"},
        "webPathType": {"type": "string", "enum": ["Prefix", "Exact", "ImplementationSpecific"]},
        "apiEnabled": {"type": "boolean"},
        "apiPath": {"type": "string"},
        "apiPathType": {"type": "string", "enum": ["Prefix", "Exact", "ImplementationSpecific"]},
        "tls": {"type": "array"}
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "serviceMonitor": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": {"type": "boolean"},
            "namespace": {"type": "string"},
            "interval": {"type": "string"},
            "scrapeTimeout": {"type": "string"},
            "path": {"type": "string"},
            "additionalLabels": {"type": "object"}
          }
        }
      }
    },
    "externalSecrets": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {"type": "boolean"},
        "refreshInterval": {"type": "string"},
        "secretStoreRef": {
          "type": "object",
          "properties": {
            "kind": {"type": "string", "enum": ["SecretStore", "ClusterSecretStore"]},
            "name": {"type": "string"}
          }
        },
        "data": {"type": "object"}
      }
    },
    "postgresql": {
      "type": "object",
      "required": ["enabled"],
      "properties": {"enabled": {"type": "boolean"}}
    },
    "redis": {
      "type": "object",
      "required": ["enabled"],
      "properties": {"enabled": {"type": "boolean"}}
    },
    "nodeSelector": {"type": "object"},
    "tolerations": {"type": "array"},
    "affinity": {"type": "object"}
  }
}
