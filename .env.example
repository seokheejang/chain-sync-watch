# Copy to .env and fill in. Never commit .env.
# All values are placeholders.

# -------------------- Database --------------------
# Matches docker-compose defaults so `make up` + this .env work as-is.
DATABASE_URL=postgres://csw:csw@localhost:5432/csw?sslmode=disable

# docker-compose also reads these (keep in sync with DATABASE_URL above).
POSTGRES_USER=csw
POSTGRES_PASSWORD=csw
POSTGRES_DB=csw
POSTGRES_PORT=5432

# -------------------- Redis --------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# asynqmon web UI (docker compose --profile tools up -d)
ASYNQMON_PORT=8081

# -------------------- Master encryption key (Phase 10a) --------------------
# AES-GCM master key the server uses to encrypt/decrypt 3rd-party API
# credentials (Etherscan / Blockscout / user indexer) stored in the
# sources table. 32 bytes, base64-encoded.
#
# Generate with:   openssl rand -base64 32
#
# Never commit the actual value. Rotating this key requires re-
# encrypting every sources row — do not change casually once data
# exists. Losing the key makes stored secrets unrecoverable.
CSW_SECRET_KEY=

# -------------------- Etherscan adapter (optional) --------------------
# Paste your Etherscan V2 API key, then flip ENABLED to true.
CSW_ADAPTERS__ETHERSCAN__API_KEY=
CSW_ADAPTERS__ETHERSCAN__ENABLED=false

# -------------------- Chain RPC override (per chain id) --------------------
# Override the public default (defaults.yaml) with your own node.
# archive=true for full historical balance/nonce; false for light-sync.
#
# CSW_ADAPTERS__RPC__ENDPOINTS__10=http://your-archive-node:8545
# CSW_ADAPTERS__RPC__ARCHIVE=true
# CSW_ADAPTERS__RPC__RATE_LIMIT_RPS=20

# -------------------- Arbitrary YAML overrides --------------------
# Convention: CSW_ prefix; double underscore "__" separates nested keys;
# single underscore "_" stays literal inside a key segment.
#
# Examples:
# CSW_SERVER__ADDR=:9090
# CSW_LOG__LEVEL=debug
# CSW_VERIFICATION__MAX_CONCURRENT_PER_SOURCE=10

# -------------------- Custom adapter endpoints (user-defined) --------------------
# Consumed only by user-maintained adapters in private/ or
# examples/custom-graphql-adapter/. Never commit real internal URLs.
# CUSTOM_GRAPHQL_ADAPTER_ENDPOINT=
